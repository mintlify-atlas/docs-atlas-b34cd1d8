  "keyFeatures": [
    "Multi-agent AI team orchestration with specialized roles",
    "Discord selfbot with intelligent chat responses and context awareness",
    "E2B sandbox for secure code execution and Python runtime",
    "Advanced context management with PostgreSQL-backed message cache",
    "Real-time conversation summarization with TL;DR command",
    "User memory persistence and bio/avatar fetching tools",
    "MCP (Model Context Protocol) tool integration",
    "Phoenix tracing and observability for agent operations",
    "Background message backfill and sync for complete history",
    "Support for multiple LLM providers (Groq, OpenAI-compatible APIs)"
  ],
  "publicApiSurface": [
    "SelfBot(token, prefix) - Discord selfbot wrapper",
    "async_ask_junkie(user_text, user_id, session_id, images, client) - Main agent interaction",
    "get_or_create_team(user_id, client) - Retrieve or create user's AI team",
    "create_team_for_user(user_id, client) - Factory for creating agent teams",
    "setup_chat(bot) - Initialize chat handler with bot instance",
    "setup_tldr(bot) - Initialize TL;DR summarization command",
    "E2BToolkit - Sandbox management and code execution toolkit",
    "HistoryTools.read_chat_history(limit) - Fetch message history",
    "BioTools.get_user_details(user_id) - Fetch Discord user info",
    "BioTools.get_user_avatar(user_id) - Fetch user avatar image",
    "init_db() - Initialize PostgreSQL database connection",
    "get_messages(channel_id, limit) - Retrieve cached messages",
    "backfill_channel(channel, target_limit) - Backfill message history"
  ]
}
